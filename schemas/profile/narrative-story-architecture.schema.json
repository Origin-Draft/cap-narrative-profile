{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "narrative-story-architecture.schema.json",
  "title": "Narrative Profile — Story Architecture",
  "description": "Schema for the corpus-level story_architecture object in a NarrativeCorpus.",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Story title."
    },
    "genre": {
      "type": "string",
      "description": "Primary genre slug."
    },
    "genre_secondary": {
      "type": "string",
      "description": "Secondary genre (hybridization)."
    },
    "structure_type": {
      "type": "string",
      "description": "Macro structure type (three_act, two_act, kishotenketsu, etc.)."
    },
    "act_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of acts."
    },
    "chapter_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of chapters."
    },
    "collision_type": {
      "type": "string",
      "description": "Structural collision type (person_vs_self, person_vs_society, etc.)."
    },
    "inciting_incident": {
      "type": "object",
      "description": "The event that disrupts story equilibrium.",
      "properties": {
        "chapter":       { "type": "integer", "minimum": 1 },
        "incident_type": { "type": "string" },
        "description":   { "type": "string" }
      },
      "additionalProperties": false
    },
    "protagonist_arc": {
      "type": "object",
      "description": "Protagonist arc design.",
      "properties": {
        "arc_direction":       { "type": "string" },
        "drive_model":         { "type": "string" },
        "lie_believed":        { "type": "string" },
        "truth_needed":        { "type": "string" },
        "wound_slug":          { "type": "string" },
        "want_need_alignment": { "type": "string", "enum": ["aligned", "misaligned", "partially_aligned"] }
      },
      "additionalProperties": false
    },
    "antagonist": {
      "type": "object",
      "description": "Antagonist design.",
      "properties": {
        "entity_slug":      { "type": "string" },
        "antagonist_type":  { "type": "string" },
        "arc_type":         { "type": "string" },
        "opposition_level": { "type": "string" },
        "thematic_mirror":  { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "controlling_idea": {
      "type": "string",
      "description": "Egri / McKee controlling idea."
    },
    "genre_promise": {
      "type": "string",
      "description": "The promise to the reader (genre contract)."
    },
    "power_asymmetry": {
      "type": "string",
      "description": "Which social world has structural advantage."
    },
    "themes": {
      "type": "array",
      "description": "Story-level thematic claims.",
      "items": {
        "type": "object",
        "properties": {
          "theme":           { "type": "string", "minLength": 1 },
          "controlling_idea": { "type": "string" }
        },
        "required": ["theme"],
        "additionalProperties": false
      }
    },
    "beat_sequence": {
      "type": "array",
      "description": "Macro-arc beat sequence.",
      "items": {
        "type": "object",
        "properties": {
          "beat":        { "type": "string", "minLength": 1 },
          "chapter":     { "type": "integer", "minimum": 1 },
          "scene":       { "type": "integer", "minimum": 1 },
          "description": { "type": "string" }
        },
        "required": ["beat"],
        "additionalProperties": false
      }
    },
    "motifs": {
      "type": "array",
      "description": "Story-level recurring motifs.",
      "items": {
        "type": "object",
        "properties": {
          "motif":       { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        },
        "required": ["motif"],
        "additionalProperties": false
      }
    },
    "actantial_map": {
      "description": "Greimas actantial map (free-form).",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
