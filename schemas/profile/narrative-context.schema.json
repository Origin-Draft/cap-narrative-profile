{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "narrative-context.schema.json",
  "title": "Narrative Profile — Unit Observables Context",
  "description": "Profile overlay schema constraining unit.observables.context for the narrative profile. Fields reference governed enums from enums.schema.json.",
  "type": "object",
  "properties": {
    "focalizer": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Registry character slug for the perceiving character. REQUIRED for unit_type 'scene'."
    },
    "pov": {
      "$ref": "../enums.schema.json#/$defs/pov_type",
      "description": "Point of view type. REQUIRED for unit_type 'scene'."
    },
    "setting": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Registry setting slug. SHOULD resolve to entity_type 'location'."
    },
    "diegetic_level": {
      "$ref": "../enums.schema.json#/$defs/diegetic_level",
      "description": "Genette diegetic level."
    },
    "time_of_day": {
      "$ref": "../enums.schema.json#/$defs/time_of_day",
      "description": "When the unit occurs."
    },
    "season": {
      "$ref": "../enums.schema.json#/$defs/season",
      "description": "Season in which the unit occurs."
    },
    "atmosphere": {
      "$ref": "../enums.schema.json#/$defs/tone",
      "description": "Environmental mood (uses tone vocabulary)."
    },
    "spatial_structure": {
      "$ref": "../enums.schema.json#/$defs/spatial_structure",
      "description": "Spatial configuration."
    },
    "narrative_time": {
      "type": "object",
      "description": "Genette temporal architecture.",
      "properties": {
        "order": {
          "$ref": "../enums.schema.json#/$defs/narrative_order",
          "description": "Narrative order."
        },
        "duration_mode": {
          "$ref": "../enums.schema.json#/$defs/duration_mode",
          "description": "Genette duration."
        },
        "frequency": {
          "$ref": "../enums.schema.json#/$defs/frequency",
          "description": "Genette frequency."
        },
        "analepsis_type": {
          "$ref": "../enums.schema.json#/$defs/analepsis_type",
          "description": "Type of analepsis (flashback), if order involves analepsis."
        },
        "prolepsis_type": {
          "$ref": "../enums.schema.json#/$defs/prolepsis_type",
          "description": "Type of prolepsis (flash-forward), if order involves prolepsis."
        },
        "analepsis_reach": {
          "type": "object",
          "description": "How far back the analepsis reaches.",
          "properties": {
            "value": { "type": "number", "minimum": 0 },
            "unit": { "$ref": "../enums.schema.json#/$defs/time_unit" }
          },
          "additionalProperties": false
        },
        "analepsis_extent": {
          "type": "object",
          "description": "Duration the analepsis covers in story time.",
          "properties": {
            "value": { "type": "number", "minimum": 0 },
            "unit": { "$ref": "../enums.schema.json#/$defs/time_unit" }
          },
          "additionalProperties": false
        },
        "iterative_pattern": {
          "$ref": "../enums.schema.json#/$defs/iterative_pattern",
          "description": "Type of iterative telling pattern, if frequency is iterative."
        },
        "story_duration": {
          "type": "object",
          "description": "Duration of story time covered by this unit.",
          "properties": {
            "value": { "type": "number", "minimum": 0 },
            "unit": { "$ref": "../enums.schema.json#/$defs/time_unit" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "continuity": {
      "type": "object",
      "description": "Inter-unit continuity: how this unit connects to the previous one.",
      "properties": {
        "time_elapsed": {
          "$ref": "../enums.schema.json#/$defs/continuity_time_elapsed",
          "description": "Time elapsed since the previous unit."
        },
        "location_change": {
          "$ref": "../enums.schema.json#/$defs/location_change_type",
          "description": "Whether and how the location changed from the previous unit."
        },
        "temporal_gap_type": {
          "$ref": "../enums.schema.json#/$defs/temporal_gap_type",
          "description": "Nature of any temporal gap from the previous unit."
        }
      },
      "additionalProperties": false
    },
    "character_positions": {
      "type": "object",
      "description": "Which characters are present, arriving, or departing in this unit.",
      "properties": {
        "present": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "description": "Registry character slugs of characters present throughout the unit."
        },
        "arrives": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "entity": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
              "arrival_type": { "$ref": "../enums.schema.json#/$defs/character_arrival" }
            },
            "required": ["entity"],
            "additionalProperties": false
          },
          "description": "Characters who arrive during the unit."
        },
        "departs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "entity": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
              "departure_type": { "$ref": "../enums.schema.json#/$defs/character_departure" }
            },
            "required": ["entity"],
            "additionalProperties": false
          },
          "description": "Characters who depart during the unit."
        }
      },
      "additionalProperties": false
    },
    "social_circle": {
      "type": "object",
      "description": "Social dynamics of the scene space.",
      "properties": {
        "dominant": {
          "$ref": "../enums.schema.json#/$defs/dominant_social_circle",
          "description": "Which social world dominates the scene."
        },
        "intersection": {
          "$ref": "../enums.schema.json#/$defs/circle_intersection",
          "description": "How social circles interact or collide."
        },
        "territory": {
          "$ref": "../enums.schema.json#/$defs/character_territory",
          "description": "Whose home territory the scene occurs in."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
