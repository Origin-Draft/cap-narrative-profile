{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gbr-protocol.dev/schemas/v0/registry.schema.json",
  "title": "EntityRegistry",
  "description": "Per-book entity registry defining the controlled vocabulary of characters, settings, relationships, and want types. Source of truth for all entity references.",
  "type": "object",
  "required": ["book_id", "characters", "settings"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "book_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Unique snake-case book identifier"
    },
    "title": {
      "type": "string",
      "description": "Human-readable book title"
    },
    "author": {
      "type": "string",
      "description": "Author name"
    },

    "characters": {
      "type": "object",
      "description": "Map of character slug → Character",
      "additionalProperties": { "$ref": "#/$defs/character" }
    },

    "relationships": {
      "type": "array",
      "description": "Directed relationship edges",
      "items": { "$ref": "#/$defs/relationship" }
    },

    "settings": {
      "type": "object",
      "description": "Map of setting slug → Setting",
      "additionalProperties": { "$ref": "#/$defs/setting" }
    },

    "want_vocabulary": {
      "type": "object",
      "description": "Map of want slug → display label for canonical summaries",
      "additionalProperties": { "type": "string" }
    },

    "narrator": {
      "$ref": "#/$defs/narrator",
      "description": "Narrative voice definition with optional voice embedding for continuity tracking"
    }
  },

  "$defs": {
    "character": {
      "type": "object",
      "required": ["observables"],
      "properties": {
        "observables": {
          "type": "object",
          "description": "Factual identifiers for this character.",
          "required": ["id", "name"],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9_]+$",
              "description": "Snake-case slug"
            },
            "name": { "type": "string", "description": "Display name" },
            "slot": { "type": ["string", "null"], "description": "Cast template slot" }
          }
        },
        "structure": {
          "type": "object",
          "description": "Organizational role and voice design.",
          "properties": {
            "role": { "$ref": "enums.schema.json#/$defs/role" },
            "voice_signature": { "$ref": "#/$defs/voice_signature" },
            "voice_embedding": { "$ref": "#/$defs/voice_embedding" }
          }
        },
        "interpretations": {
          "type": "object",
          "description": "Inferred traits. All fields MAY use the interpreted_value wrapper.",
          "properties": {
            "archetype": {
              "oneOf": [
                { "$ref": "enums.schema.json#/$defs/archetype" },
                { "$ref": "enums.schema.json#/$defs/interpreted_value" }
              ]
            },
            "wound": {
              "oneOf": [
                { "$ref": "enums.schema.json#/$defs/wound" },
                { "$ref": "enums.schema.json#/$defs/interpreted_value" }
              ]
            },
            "alignment": {
              "oneOf": [
                { "$ref": "enums.schema.json#/$defs/alignment" },
                { "$ref": "enums.schema.json#/$defs/interpreted_value" }
              ]
            },
            "drive_model": {
              "oneOf": [
                { "$ref": "enums.schema.json#/$defs/drive_model" },
                { "$ref": "enums.schema.json#/$defs/interpreted_value" }
              ]
            },
            "arc_type": {
              "oneOf": [
                { "$ref": "enums.schema.json#/$defs/arc_type" },
                { "$ref": "enums.schema.json#/$defs/interpreted_value" }
              ]
            },
            "actant": {
              "oneOf": [
                { "$ref": "enums.schema.json#/$defs/actant" },
                { "$ref": "enums.schema.json#/$defs/interpreted_value" }
              ]
            },
            "ghost": { "type": ["string", "null"], "description": "Internal wound origin" },
            "want": { "type": ["string", "null"], "description": "External goal" },
            "need": { "type": ["string", "null"], "description": "Thematic truth needed" },
            "flaw": { "type": ["string", "null"], "description": "Fatal flaw" }
          }
        }
      }
    },

    "relationship": {
      "type": "object",
      "required": ["observables"],
      "properties": {
        "observables": {
          "type": "object",
          "description": "Factual endpoints of the relationship.",
          "required": ["source", "target"],
          "properties": {
            "source": { "type": "string", "pattern": "^[a-z0-9_]+$", "description": "Source character slug" },
            "target": { "type": "string", "pattern": "^[a-z0-9_]+$", "description": "Target character slug" }
          }
        },
        "structure": {
          "type": "object",
          "description": "Relationship classification.",
          "required": ["rel_type"],
          "properties": {
            "rel_type": { "$ref": "enums.schema.json#/$defs/relationship_type" }
          }
        },
        "interpretations": {
          "type": "object",
          "description": "Inferred dynamics. All fields MAY use the interpreted_value wrapper.",
          "properties": {
            "description": { "type": ["string", "null"] },
            "dynamic_at_start": {
              "oneOf": [
                { "$ref": "enums.schema.json#/$defs/relationship_dynamic" },
                { "$ref": "enums.schema.json#/$defs/interpreted_value" }
              ]
            },
            "dynamic_at_end": {
              "oneOf": [
                { "$ref": "enums.schema.json#/$defs/relationship_dynamic" },
                { "$ref": "enums.schema.json#/$defs/interpreted_value" }
              ]
            },
            "power_balance": {
              "oneOf": [
                { "$ref": "enums.schema.json#/$defs/power_balance" },
                { "$ref": "enums.schema.json#/$defs/interpreted_value" }
              ]
            }
          }
        }
      }
    },

    "setting": {
      "type": "object",
      "required": ["observables"],
      "properties": {
        "observables": {
          "type": "object",
          "description": "Factual identifiers for this setting.",
          "required": ["id", "name"],
          "properties": {
            "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
            "name": { "type": "string", "description": "Display name" }
          }
        },
        "structure": {
          "type": "object",
          "description": "Setting classification.",
          "properties": {
            "type": { "$ref": "enums.schema.json#/$defs/setting_type" }
          }
        },
        "interpretations": {
          "type": "object",
          "description": "Inferred atmospheric qualities.",
          "properties": {
            "general_vibe": { "type": ["string", "null"] },
            "sensory_signature": {
              "type": "array",
              "items": { "type": "string" },
              "maxItems": 3,
              "description": "Three defining sensory details"
            }
          }
        }
      }
    },

    "voice_signature": {
      "type": "object",
      "description": "Character voice fingerprint",
      "properties": {
        "sentence_length_tendency": {
          "type": ["string", "null"],
          "enum": ["short", "medium", "long", "varied", null]
        },
        "vocabulary_register": {
          "type": ["string", "null"],
          "enum": ["colloquial", "standard", "formal", "archaic", "mixed", null]
        },
        "syntax_complexity": {
          "type": ["string", "null"],
          "enum": ["simple", "moderate", "complex", null]
        },
        "fid_markers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Free indirect discourse markers"
        },
        "forbidden_words": {
          "type": "array",
          "items": { "type": "string" }
        },
        "signature_phrases": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "voice_embedding": {
      "type": "object",
      "description": "Learned voice representation for continuity tracking. Created from author-provided samples.",
      "properties": {
        "model": {
          "type": "string",
          "description": "Embedding model identifier (e.g., text-embedding-3-small)"
        },
        "source_type": {
          "type": "string",
          "enum": ["dialogue_only", "fid_passages", "all_speech", "mixed"],
          "description": "What prose was used to generate the embedding"
        },
        "sample_word_count": {
          "type": "integer",
          "minimum": 100,
          "description": "Total words in source samples"
        },
        "vector": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Embedding vector (dimension depends on model)"
        }
      },
      "required": ["model", "source_type", "vector"]
    },

    "narrator": {
      "type": "object",
      "description": "Narrative voice definition — the voice that speaks when no character is focalized",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["first_person", "third_limited", "third_omniscient", "second_person", "frame_narrator"],
          "description": "Narrator type per Genette/Stanzel"
        },
        "voice_signature": { "$ref": "#/$defs/voice_signature" },
        "voice_embedding": { "$ref": "#/$defs/voice_embedding" },
        "reliability": {
          "type": "string",
          "enum": ["reliable", "unreliable", "ambiguous"],
          "description": "Booth's narrator reliability classification"
        },
        "distance": {
          "type": "string",
          "enum": ["intimate", "close", "neutral", "distant", "ironic"],
          "description": "Gardner's psychic distance default for narrator"
        }
      }
    }
  }
}
