{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gbr-protocol.dev/schemas/v0/story-architecture.schema.json",
  "title": "StoryArchitecture",
  "description": "Book-level structural metadata. v0.2.0: fields organized into observables/structure/interpretations epistemic sections.",
  "type": "object",
  "required": ["book_id", "structure"],
  "properties": {
    "book_id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "title": { "type": "string" },
    "author": { "type": "string" },

    "observables": {
      "type": "object",
      "description": "Facts directly grounded in the artifact.",
      "properties": {
        "inciting_incident_chapter": {
          "type": "integer",
          "description": "Chapter in which the inciting incident occurs"
        }
      }
    },

    "structure": {
      "type": "object",
      "description": "How the narrative is organized at book level.",
      "required": ["genre"],
      "properties": {
        "genre": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/genre_type" },
            {
              "type": "object",
              "required": ["primary"],
              "properties": {
                "primary": { "$ref": "enums.schema.json#/$defs/genre_type" },
                "secondary": { "$ref": "enums.schema.json#/$defs/genre_type" },
                "subgenre": { "type": "string" }
              }
            }
          ],
          "description": "Genre — string slug or object with primary/secondary/subgenre"
        },
        "collision_architecture": {
          "type": "object",
          "description": "Social circle collision dynamics (Grimoire Phase 02)",
          "properties": {
            "collision_type": { "$ref": "enums.schema.json#/$defs/collision_type" },
            "collision_pattern": { "$ref": "enums.schema.json#/$defs/collision_pattern" }
          }
        },
        "inciting_incident": {
          "type": "object",
          "properties": {
            "type": { "$ref": "enums.schema.json#/$defs/inciting_incident_type" },
            "description": { "type": "string" }
          }
        },
        "act_count": { "type": "integer", "minimum": 1, "maximum": 5 },
        "chapter_count": { "type": "integer" },
        "word_count": { "type": "integer" },
        "diegetic_level": { "$ref": "enums.schema.json#/$defs/diegetic_level" },
        "has_frame_narrative": { "type": "boolean" },
        "actantial_map": {
          "type": "array",
          "description": "Greimas actantial model mapping",
          "items": {
            "type": "object",
            "required": ["character_slug", "actantial_role"],
            "properties": {
              "character_slug": { "type": "string" },
              "character_role": { "$ref": "enums.schema.json#/$defs/character_role" },
              "actantial_role": { "$ref": "enums.schema.json#/$defs/actantial_role" }
            }
          }
        }
      }
    },

    "interpretations": {
      "type": "object",
      "description": "Inferred meaning. All fields MAY use the interpreted_value wrapper.",
      "properties": {
        "power_asymmetry": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/power_asymmetry_type" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "antagonist": {
          "type": "object",
          "description": "Primary antagonist design (Truby thematic mirror)",
          "properties": {
            "antagonist_type": { "$ref": "enums.schema.json#/$defs/antagonist_type" },
            "arc_type": { "$ref": "enums.schema.json#/$defs/antagonist_arc_type" },
            "opposition_level": { "$ref": "enums.schema.json#/$defs/opposition_level" },
            "thematic_mirror": { "type": "boolean" }
          }
        },
        "protagonist_arc": {
          "type": "object",
          "description": "Protagonist arc design",
          "properties": {
            "arc_direction": { "$ref": "enums.schema.json#/$defs/arc_direction" },
            "drive_model": { "$ref": "enums.schema.json#/$defs/drive_model" },
            "lie_believed": { "type": "string", "description": "Weiland/Cron: false belief at story start" },
            "truth_needed": { "type": "string", "description": "Truth protagonist must learn" },
            "want_need_alignment": { "$ref": "enums.schema.json#/$defs/want_need_alignment" },
            "wound_slug": { "type": "string", "description": "Character's wound slug in registry" }
          }
        },
        "transtextuality": {
          "type": "object",
          "description": "Genette transtextual relations",
          "properties": {
            "intertexts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "source_text": { "type": "string" },
                  "relation_type": { "$ref": "enums.schema.json#/$defs/transtextuality_type" },
                  "description": { "type": "string" }
                }
              }
            },
            "architext_genre": { "type": "string", "description": "Genre tradition the text participates in" }
          }
        },
        "themes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "theme": { "type": "string" },
              "controlling_idea": { "type": "string", "description": "McKee: value + cause" },
              "thematic_question": { "$ref": "enums.schema.json#/$defs/thematic_question" }
            }
          }
        }
      }
    }
  }
}
