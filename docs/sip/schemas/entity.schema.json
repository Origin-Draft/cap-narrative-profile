{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "entity.schema.json",
  "title": "SIP Entity",
  "description": "A persistent participant or object of interest that exists across multiple Units.",
  "type": "object",
  "properties": {
    "entity_id": {
      "$ref": "_base.schema.json#/$defs/slug",
      "description": "Unique within artifact."
    },
    "entity_type": {
      "type": "string",
      "minLength": 1,
      "description": "Profile-defined type (e.g., character, service)."
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable name."
    },
    "observable_descriptors": {
      "type": "object",
      "description": "Profile-defined observable properties.",
      "additionalProperties": true
    },
    "structural_properties": {
      "type": "object",
      "description": "Profile-defined structural properties.",
      "additionalProperties": true
    },
    "interpretations": {
      "type": "object",
      "description": "Profile-defined interpretive properties.",
      "additionalProperties": true
    }
  },
  "required": ["entity_id", "entity_type", "display_name"],
  "additionalProperties": false
}
