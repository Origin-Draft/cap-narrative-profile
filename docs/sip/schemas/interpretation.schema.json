{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "interpretation.schema.json",
  "title": "SIP Interpretation (standalone)",
  "description": "A standalone interpretive claim about another object.",
  "type": "object",
  "properties": {
    "target_ref": {
      "$ref": "_base.schema.json#/$defs/object_ref",
      "description": "Reference to the object this interprets."
    },
    "interpretation_type": {
      "type": "string",
      "minLength": 1,
      "description": "Profile-defined interpretation type."
    },
    "value": {
      "$ref": "_base.schema.json#/$defs/interpreted_value",
      "description": "The interpretive claim."
    },
    "confidence": {
      "$ref": "_base.schema.json#/$defs/confidence"
    },
    "rationale": {
      "type": "string",
      "description": "Why this interpretation is asserted."
    },
    "evidence_refs": {
      "type": "array",
      "items": { "$ref": "_base.schema.json#/$defs/object_ref" },
      "description": "References to supporting evidence."
    },
    "source": {
      "$ref": "_base.schema.json#/$defs/provenance_source",
      "description": "Who or what produced this interpretation."
    }
  },
  "required": ["target_ref", "interpretation_type", "value"],
  "additionalProperties": false
}
