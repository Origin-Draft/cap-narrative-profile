{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "artifact.schema.json",
  "title": "SIP Artifact",
  "description": "Top-level container: a complete canonical decomposition of one source work.",
  "type": "object",
  "properties": {
    "protocol": {
      "type": "string",
      "const": "semantic-interaction-protocol",
      "description": "MUST be 'semantic-interaction-protocol'."
    },
    "protocol_version": {
      "$ref": "_base.schema.json#/$defs/semver",
      "description": "SIP version this artifact conforms to."
    },
    "profile": {
      "type": "string",
      "minLength": 1,
      "description": "Domain profile identifier (e.g., 'narrative', 'software')."
    },
    "profile_version": {
      "$ref": "_base.schema.json#/$defs/semver",
      "description": "Profile version."
    },
    "artifact_id": {
      "$ref": "_base.schema.json#/$defs/slug",
      "description": "Unique identifier for this artifact."
    },
    "metadata": {
      "type": "object",
      "description": "Domain-agnostic metadata (title, owner, size, creation date).",
      "additionalProperties": true
    },
    "entities": {
      "type": "array",
      "items": { "$ref": "entity.schema.json" },
      "minItems": 1,
      "description": "All persistent entities declared in this artifact."
    },
    "units": {
      "type": "array",
      "items": { "$ref": "unit.schema.json" },
      "minItems": 1,
      "description": "Ordered decomposition into atomic units."
    },
    "relationships": {
      "type": "array",
      "items": { "$ref": "relationship.schema.json" },
      "description": "Cross-entity and cross-unit links."
    },
    "views": {
      "type": "array",
      "items": { "$ref": "view.schema.json" },
      "description": "Named projections over the canonical data."
    },
    "interpretations": {
      "description": "Artifact-level inferences (themes, architectural style, etc.).",
      "oneOf": [
        {
          "type": "array",
          "items": { "$ref": "interpretation.schema.json" }
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    }
  },
  "required": [
    "protocol",
    "protocol_version",
    "profile",
    "profile_version",
    "artifact_id",
    "entities",
    "units"
  ],
  "additionalProperties": true
}
