{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "unit.schema.json",
  "title": "SIP Unit",
  "description": "An atomic transformation or interaction block within an artifact.",
  "type": "object",
  "properties": {
    "unit_id": {
      "$ref": "_base.schema.json#/$defs/slug",
      "description": "Unique within artifact."
    },
    "artifact_id": {
      "$ref": "_base.schema.json#/$defs/slug",
      "description": "Back-reference to parent artifact."
    },
    "unit_type": {
      "type": "string",
      "minLength": 1,
      "description": "Profile-defined unit type."
    },
    "sequence_index": {
      "type": "integer",
      "minimum": 1,
      "description": "Position in artifact's primary ordering."
    },
    "observables": {
      "type": "object",
      "description": "What can be directly observed in this unit.",
      "properties": {
        "participants": {
          "type": "array",
          "items": { "$ref": "_base.schema.json#/$defs/entity_ref" },
          "minItems": 1,
          "description": "Entities involved in this unit."
        },
        "context": {
          "type": "object",
          "description": "Profile-defined contextual observables.",
          "additionalProperties": true
        },
        "event_type": {
          "type": "string",
          "description": "Profile-defined event classification."
        },
        "source_text": {
          "type": "string",
          "description": "Raw artifact text or content this unit was derived from."
        }
      },
      "required": ["participants"],
      "additionalProperties": true
    },
    "structure": {
      "type": "object",
      "description": "Structural role and decomposition.",
      "properties": {
        "position": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Normalized position in artifact."
        },
        "causal_role": {
          "$ref": "_base.schema.json#/$defs/causal_role_core",
          "description": "Function in causal chain. Profiles MAY extend."
        },
        "grouping": {
          "type": "object",
          "description": "Profile-defined grouping metadata.",
          "additionalProperties": true
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "step.schema.json" },
          "description": "Ordered sub-unit decomposition."
        },
        "transition": {
          "$ref": "transition.schema.json",
          "description": "Value change within this unit."
        },
        "semantic_fingerprint": {
          "description": "Machine-verifiable semantic summary. Profile defines grammar."
        }
      },
      "additionalProperties": true
    },
    "interpretations": {
      "type": "object",
      "description": "Unit-level interpretive claims. All fields profile-defined.",
      "additionalProperties": true
    },
    "participant_states": {
      "type": "array",
      "items": { "$ref": "participant-state.schema.json" },
      "description": "Per-entity state snapshots."
    },
    "metadata": {
      "type": "object",
      "description": "Size, word count, LOC, etc.",
      "additionalProperties": true
    }
  },
  "required": ["unit_id", "artifact_id", "sequence_index", "observables"],
  "additionalProperties": false
}
