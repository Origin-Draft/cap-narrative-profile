{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "relationship.schema.json",
  "title": "SIP Relationship",
  "description": "A typed, directed link between two entities, two units, or an entity and a unit.",
  "type": "object",
  "properties": {
    "source": {
      "$ref": "_base.schema.json#/$defs/object_ref",
      "description": "Entity or unit ID."
    },
    "target": {
      "$ref": "_base.schema.json#/$defs/object_ref",
      "description": "Entity or unit ID."
    },
    "relationship_type": {
      "type": "string",
      "minLength": 1,
      "description": "Profile-defined relationship type."
    },
    "evidence": {
      "type": "string",
      "description": "Observable basis for the relationship."
    },
    "interpretations": {
      "type": "object",
      "description": "Profile-defined interpretive properties.",
      "additionalProperties": true
    }
  },
  "required": ["source", "target", "relationship_type"],
  "additionalProperties": false
}
