{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "transition.schema.json",
  "title": "SIP Transition",
  "description": "The change from one state to another within or across Units.",
  "type": "object",
  "properties": {
    "subject": {
      "$ref": "_base.schema.json#/$defs/object_ref",
      "description": "Entity or unit undergoing the transition."
    },
    "before": {
      "$ref": "state.schema.json",
      "description": "Pre-transition state."
    },
    "after": {
      "$ref": "state.schema.json",
      "description": "Post-transition state."
    },
    "trigger": {
      "type": "string",
      "description": "What caused the change."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable statement of what changed (the delta). MUST state a change, not a condition."
    },
    "confidence": {
      "$ref": "_base.schema.json#/$defs/confidence"
    },
    "grounding": {
      "type": "string",
      "description": "Evidence from the source artifact."
    }
  },
  "required": ["description"],
  "additionalProperties": false
}
