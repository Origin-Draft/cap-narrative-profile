{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "step.schema.json",
  "title": "SIP Step",
  "description": "An ordered atomic action within a Unit.",
  "type": "object",
  "properties": {
    "sequence_number": {
      "type": "integer",
      "minimum": 1,
      "description": "Order within the unit."
    },
    "agent": {
      "$ref": "_base.schema.json#/$defs/entity_ref",
      "description": "Entity performing the action."
    },
    "action": {
      "type": "string",
      "minLength": 1,
      "description": "Verb or action identifier."
    },
    "target": {
      "type": "string",
      "description": "What the action is directed at (entity ref, resource path, or free text)."
    },
    "event_type": {
      "type": "string",
      "description": "Profile-defined event classification."
    },
    "significance": {
      "$ref": "_base.schema.json#/$defs/significance"
    },
    "interpretations": {
      "type": "object",
      "description": "Profile-defined step-level interpretations.",
      "additionalProperties": true
    }
  },
  "required": ["sequence_number", "agent", "action"],
  "additionalProperties": false
}
