{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "information-state.schema.json",
  "title": "SIP InformationState",
  "description": "Tracks what an entity knows, does not know, and learns within a Unit.",
  "type": "object",
  "properties": {
    "knows": {
      "type": "array",
      "items": { "$ref": "#/$defs/information_item" },
      "description": "Facts known at unit entry."
    },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/information_item" },
      "description": "Facts not known at unit entry."
    },
    "gained": {
      "type": "array",
      "items": { "$ref": "#/$defs/information_item" },
      "description": "Facts learned during the unit."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "information_item": {
      "type": "object",
      "properties": {
        "subject": {
          "type": "string",
          "description": "What the information is about (profile-defined domain)."
        },
        "predicate": {
          "type": "string",
          "description": "Epistemic relation (profile-defined: knows, believes, suspects, assumes)."
        },
        "about": {
          "type": "string",
          "description": "Entity or concept the information concerns."
        },
        "certainty": {
          "$ref": "_base.schema.json#/$defs/confidence",
          "description": "How certain the knowledge is."
        }
      },
      "required": ["subject", "predicate", "about"],
      "additionalProperties": false
    }
  }
}
