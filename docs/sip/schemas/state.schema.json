{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "state.schema.json",
  "title": "SIP State",
  "description": "A named condition attached to an entity, group, or artifact at a specific point.",
  "type": "object",
  "properties": {
    "subject": {
      "$ref": "_base.schema.json#/$defs/object_ref",
      "description": "What this state describes (entity or unit ref). Required when standalone."
    },
    "state_type": {
      "type": "string",
      "minLength": 1,
      "description": "Profile-defined state category."
    },
    "value": {
      "description": "The state value (type depends on state_type)."
    },
    "evidence": {
      "type": "string",
      "description": "Observable basis for this state."
    },
    "provenance": {
      "$ref": "_base.schema.json#/$defs/provenance_source"
    },
    "confidence": {
      "$ref": "_base.schema.json#/$defs/confidence"
    }
  },
  "required": ["state_type", "value"],
  "additionalProperties": false
}
