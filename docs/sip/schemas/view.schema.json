{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "view.schema.json",
  "title": "SIP View",
  "description": "A named projection over the canonical artifact.",
  "type": "object",
  "properties": {
    "view_id": {
      "$ref": "_base.schema.json#/$defs/slug",
      "description": "Unique within artifact."
    },
    "view_type": {
      "type": "string",
      "minLength": 1,
      "description": "Profile-defined view type."
    },
    "description": {
      "type": "string",
      "description": "What this view shows."
    },
    "scope": {
      "type": "array",
      "items": { "$ref": "_base.schema.json#/$defs/object_ref" },
      "description": "Which entities/units are included (default: all)."
    },
    "ordering": {
      "type": "string",
      "description": "How items are ordered (e.g., chronological, dependency, causal)."
    },
    "data": {
      "type": "object",
      "description": "View-specific computed data.",
      "additionalProperties": true
    }
  },
  "required": ["view_id", "view_type"],
  "additionalProperties": false
}
